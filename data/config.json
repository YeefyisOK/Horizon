{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "api_key_env": "GOOGLE_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "en",
      "zh"
    ],
    "analysis_concurrency": 5,
    "enrichment_concurrency": 3
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "whisper",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "SYSTRAN",
        "repo": "faster-whisper",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "ggerganov",
        "repo": "whisper.cpp",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "PaddlePaddle",
        "repo": "PaddleOCR",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "snakers4",
        "repo": "silero-vad",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "jianfch",
        "repo": "stable-ts",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "rss": [
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/blog/rss.xml",
        "enabled": true,
        "category": "competitor"
      },
      {
        "name": "Google AI Blog",
        "url": "https://blog.google/technology/ai/rss/",
        "enabled": true,
        "category": "competitor"
      },
      {
        "name": "Apple Developer News",
        "url": "https://developer.apple.com/news/rss/news.rss",
        "enabled": true,
        "category": "platform"
      },
      {
        "name": "Apple Machine Learning Research",
        "url": "https://machinelearning.apple.com/rss.xml",
        "enabled": true,
        "category": "platform"
      },
      {
        "name": "TechCrunch",
        "url": "https://techcrunch.com/feed/",
        "enabled": true,
        "category": "tech-news"
      },
      {
        "name": "The Verge",
        "url": "https://www.theverge.com/rss/index.xml",
        "enabled": true,
        "category": "tech-news"
      },
      {
        "name": "Ars Technica",
        "url": "https://feeds.arstechnica.com/arstechnica/index",
        "enabled": true,
        "category": "tech-news"
      },
      {
        "name": "Product Hunt",
        "url": "https://www.producthunt.com/feed",
        "enabled": true,
        "category": "launches"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "macapps",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 5
        },
        {
          "subreddit": "VideoEditing",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 10
        },
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "speechrecognition",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 3
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 48
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": [
      "en",
      "zh"
    ],
    "request_body": {
      "chat_id": "${HORIZON_TG_CHAT_ID}",
      "text": "#{summary?limit=4000&split=---}",
      "parse_mode": "Markdown",
      "disable_web_page_preview": true
    },
    "headers": ""
  }
}
